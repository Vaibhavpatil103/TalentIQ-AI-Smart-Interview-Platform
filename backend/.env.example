# ─── TalentIQ Backend — Environment Variables ────────────────────
# Copy this file to .env and fill in your values.
# Required vars are marked with [REQUIRED].

# ─── Core ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# [REQUIRED] MongoDB connection string
DB_URL=mongodb+srv://user:password@cluster.mongodb.net/talentiq

# [REQUIRED] Frontend URL (for CORS + email links)
CLIENT_URL=http://localhost:5173

# ─── Authentication (Clerk) ──────────────────────────────────────
# [REQUIRED] Get these from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── Stream.io (Video + Chat) ───────────────────────────────────
# [REQUIRED] Get these from https://dashboard.getstream.io
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# ─── Background Jobs (Inngest) ──────────────────────────────────
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key

# ─── AI Providers (set at least one) ────────────────────────────
CLAUDE_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...
DEEPSEEK_API_KEY=sk-...
NVIDIA_API_KEY=nvapi-...

# ─── Email ───────────────────────────────────────────────────────
RESEND_API_KEY=re_...
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# ─── Other ───────────────────────────────────────────────────────
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_certificate
